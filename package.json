{
	"name": "obsidian-ozsync",
	"version": "0.1.2",
	"description": "Sync your Obsidian vault with OZSync cloud storage, create backups, and manage files remotely.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"check": "tsc -noEmit -skipLibCheck",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"ozsync",
		"sync",
		"backup",
		"cloud",
		"storage"
	],
	"author": "OZSync Plugin Team",
	"license": "MIT",
	"devDependencies": {
		"@types/crypto-js": "^4.2.2",
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"axios": "^1.6.2",
		"crypto-js": "^4.2.0",
		"date-fns": "^3.0.6"
	}
}
